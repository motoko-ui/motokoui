{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "motokoui",
  "homepage": "https://motokoui.com",
  "items": [
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A polished button with primary, secondary, and semantic variants.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/button.tsx",
          "type": "registry:ui",
          "target": "components/ui/button.tsx"
        }
      ]
    },
    {
      "name": "rainbow-button",
      "type": "registry:ui",
      "title": "Rainbow Button",
      "description": "A black (white in dark mode) button with an animated rainbow border.",
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/rainbow-button.tsx",
          "type": "registry:ui",
          "target": "components/ui/rainbow-button.tsx"
        }
      ],
      "cssVars": {
        "theme": {
          "animate-rainbow": "rainbow var(--rainbow-speed, 2s) infinite linear"
        },
        "light": {
          "rainbow-1": "hsl(0 100% 63%)",
          "rainbow-2": "hsl(270 100% 63%)",
          "rainbow-3": "hsl(210 100% 63%)",
          "rainbow-4": "hsl(195 100% 63%)",
          "rainbow-5": "hsl(90 100% 63%)",
          "rainbow-speed": "2s"
        },
        "dark": {
          "rainbow-1": "hsl(0 100% 63%)",
          "rainbow-2": "hsl(270 100% 63%)",
          "rainbow-3": "hsl(210 100% 63%)",
          "rainbow-4": "hsl(195 100% 63%)",
          "rainbow-5": "hsl(90 100% 63%)",
          "rainbow-speed": "2s"
        }
      },
      "css": {
        "@keyframes rainbow": {
          "0%": {
            "background-position": "0%"
          },
          "100%": {
            "background-position": "200%"
          }
        }
      }
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "A text field with Motoko surface styles, hover and focus borders.",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/input.tsx",
          "type": "registry:ui",
          "target": "components/ui/input.tsx"
        }
      ]
    },
    {
      "name": "select",
      "type": "registry:ui",
      "title": "Select",
      "description": "A compound dropdown with Motoko surface styles and a simple options kit.",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/select.tsx",
          "type": "registry:ui",
          "target": "components/ui/select.tsx"
        }
      ]
    },
    {
      "name": "modal",
      "type": "registry:ui",
      "title": "Modal",
      "description": "A centered dialog with soft Motoko motion — blur, scale, and spring settle.",
      "dependencies": ["@radix-ui/react-dialog", "lucide-react", "motion"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/modal.tsx",
          "type": "registry:ui",
          "target": "components/ui/modal.tsx"
        }
      ]
    },
    {
      "name": "tabs",
      "type": "registry:ui",
      "title": "Tabs",
      "description": "Animated pill tabs with the same soft motion used in Preview/Code.",
      "dependencies": ["motion"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/tabs.tsx",
          "type": "registry:ui",
          "target": "components/ui/tabs.tsx"
        }
      ]
    },
    {
      "name": "tooltip",
      "type": "registry:ui",
      "title": "Tooltip",
      "description": "A compact Motoko hint that appears on hover or focus.",
      "dependencies": ["@radix-ui/react-tooltip"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/tooltip.tsx",
          "type": "registry:ui",
          "target": "components/ui/tooltip.tsx"
        }
      ]
    },
    {
      "name": "notch",
      "type": "registry:ui",
      "title": "Notch",
      "description": "A morphing black toolbar — the shell expands into options with staggered motion.",
      "dependencies": ["motion"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/motokoui/notch.tsx",
          "type": "registry:ui",
          "target": "components/ui/notch.tsx"
        }
      ]
    }
  ]
}
